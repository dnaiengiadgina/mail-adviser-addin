<?xml version="1.0" encoding="UTF-8"?>
<!--
  メール送信確認アドイン - manifest.xml
  対象: 新しいOutlook for Windows / Outlook on the web (Microsoft 365)
  方式: Smart Alerts (OnMessageSend イベント) + タスクパネル
  ホスト: https://dnaiengiadgina.github.io/mail-adviser-addin/
  管理者によるM365管理センターからの展開が必要です
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ============================================================
       基本設定
       ============================================================ -->
  <!-- アドイン固有のGUID（変更しないこと） -->
  <Id>6211D679-2B24-4E1A-8313-A32B5AAF9EF8</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Fujilogi Co., Ltd.</ProviderName>
  <DefaultLocale>ja-JP</DefaultLocale>

  <DisplayName DefaultValue="メール送信確認アドイン" />
  <Description DefaultValue="メール送信前に宛先・件名・添付ファイルを確認するポップアップを表示します。誤送信を防止します。" />

  <!-- アイコン（GitHub Pages で公開するPNG画像のURL） -->
  <IconUrl DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/assets/icon-128.png" />

  <!-- サポートURL -->
  <SupportUrl DefaultValue="https://github.com/dnaiengiadgina/mail-adviser-addin" />

  <!-- 対象ホスト: Outlook（メールボックス） -->
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <!-- 最低要件: Mailbox 1.1（基本動作に必要） -->
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <!-- フォーム設定（旧Outlookとの互換性のために必要） -->
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/taskpane.html" />
        <RequestedHeight>400</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- 権限: ReadWriteMailbox（宛先・本文・添付の読み取りに必要） -->
  <Permissions>ReadWriteMailbox</Permissions>

  <!-- アクティベーションルール（メール作成時に表示） -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- ============================================================
       VersionOverrides V1_0 （リボンボタン + イベント基盤）
       ============================================================ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">

    <!-- VersionOverrides V1_1 （Smart Alerts / event-based activation に必須）
         ネストすることで V1_0 非対応クライアントへのフォールバックが可能 -->
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
                      xsi:type="VersionOverridesV1_1">

      <!-- Smart Alerts に必要な最低 Mailbox バージョン: 1.12
           新しい Outlook / OWA では 1.15 以上を推奨 -->
      <Requirements>
        <bt:Sets DefaultMinVersion="1.12">
          <bt:Set Name="Mailbox" MinVersion="1.12" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- ==================================================
               ランタイム設定
               新しいOutlook/OWA: HTML ファイルを使用
               Classic Outlook on Windows: JS ファイルを使用（Override）
               ================================================== -->
          <Runtimes>
            <!-- event-based activation 用の軽量ランタイム -->
            <Runtime resid="LaunchEvent.Url" lifetime="short">
              <!-- Classic Outlook on Windows 用 JS ファイル -->
              <Override type="javascript" resid="LaunchEvent.JS.Url" />
            </Runtime>
            <!-- タスクパネル用ランタイム -->
            <Runtime resid="TaskPane.Url" lifetime="short" />
          </Runtimes>

          <DesktopFormFactor>

            <!-- タスクパネルを開くリボンボタン -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                    <Label resid="TaskPaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskPaneButton.Label" />
                      <Description resid="TaskPaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="TaskPane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- Smart Alerts: メール送信時に OnMessageSend イベントを起動 -->
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <!--
                  SendMode オプション:
                    PromptUser  = 確認ダイアログを表示（「送信する」「戻る」を選べる）
                    SoftBlock   = 警告を表示するが送信は可能
                    Block       = 条件未達成の場合は送信不可（厳格モード）
                  ここでは PromptUser（確認を促すが強制ブロックはしない）を採用
                -->
                <LaunchEvent Type="OnMessageSend"
                             FunctionName="onMessageSendHandler"
                             SendMode="PromptUser" />
              </LaunchEvents>
              <!-- event-based activation のソース（HTML: OWA/新Outlook用） -->
              <SourceLocation resid="LaunchEvent.Url" />
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <!-- リソース定義 -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16"
            DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/assets/icon-16.png" />
          <bt:Image id="Icon.32x32"
            DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/assets/icon-32.png" />
          <bt:Image id="Icon.80x80"
            DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/assets/icon-80.png" />
        </bt:Images>

        <bt:Urls>
          <!-- タスクパネル HTML -->
          <bt:Url id="TaskPane.Url"
            DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/taskpane.html" />
          <!-- event-based activation 用 HTML（新しいOutlook / OWA） -->
          <bt:Url id="LaunchEvent.Url"
            DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/src/launchevent/launchevent.html" />
          <!-- event-based activation 用 JS（Classic Outlook on Windows） -->
          <bt:Url id="LaunchEvent.JS.Url"
            DefaultValue="https://dnaiengiadgina.github.io/mail-adviser-addin/src/launchevent/launchevent.js" />
        </bt:Urls>

        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="誤送信対策" />
          <bt:String id="TaskPaneButton.Label" DefaultValue="送信確認" />
          <bt:String id="TaskPaneButton.Tooltip"
            DefaultValue="送信前に宛先・件名・添付ファイルを確認します" />
        </bt:ShortStrings>

        <bt:LongStrings>
          <bt:String id="TaskPaneButton.Tooltip"
            DefaultValue="メール送信前に宛先・件名・添付ファイルの内容を確認できます。誤送信防止にご活用ください。" />
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
    <!-- End VersionOverrides V1_1 -->

  </VersionOverrides>
  <!-- End VersionOverrides V1_0 -->

</OfficeApp>
